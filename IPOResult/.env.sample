# IPO Result Checker Configuration
# Copy this file to .env and fill in your BOID numbers

# Your BOID numbers (comma-separated for multiple BOIDs)
# Example: BOID=xxxxxxxxxxxxx,yyyyyyyyyyyyyyyyyy,zzzzzzzzzzzzzzzzz
BOID=xxxxxxxxxxxxx

# Chrome driver path (optional, defaults to /opt/homebrew/bin/chromedriver)
# CHROMEDRIVER_PATH=/opt/homebrew/bin/chromedriver
